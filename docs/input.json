{
  "input_schema": {
    "session_id": "string — 익명 세션 식별자",
    "submitted_at": "string(ISO8601) — 입력 제출 시각",
    "user_type": "enum['comfort','explorer'] — comfort=가까움 우선, explorer=숲의 질(피톤치드) 우선",
    "health_goal": "enum['수면','스트레스','피로','우울','면역','일반']",
    "location": {
      "lat": "number — 출발지 위도",
      "lon": "number — 출발지 경도",
      "label": "string(optional) — 예: '서울 강남구'"
    },
    "visit_plan": {
      "date": "string(YYYY-MM-DD) — 방문 희망일",
      "arrival_hour": "integer(0-23) — 도착 희망 시각(시)"
    },
    "transport": {
      "mode": "enum['transit','car','walk']",
      "needs_route": "boolean — 추천 동선 제공 여부",
      "max_travel_minutes": "integer(optional) — 감내 편도 이동시간(분)"
    },
    "preferences": {
      "wants_program": "boolean — 프로그램 추천 포함",
      "wants_food": "boolean — 주변 맛집 추천 포함",
      "wants_nearby": "boolean — 주변 관광/문화시설 포함",
      "companions": "enum['solo','family','group'](optional)"
    },
    "kpomsb_pre": {
      "긴장": "number — 낮을수록 좋음",
      "우울": "number — 낮을수록 좋음",
      "분노": "number — 낮을수록 좋음",
      "활력": "number — 높을수록 좋음",
      "피로": "number — 낮을수록 좋음",
      "혼란": "number — 낮을수록 좋음"
    },
    "consent": {
      "data_use_agreed": "boolean(required) — 데이터 활용 동의",
      "followup_optin": "boolean — 사후설문 알림 수신 동의"
    }
  },

# =============================================================
# 회복의 숲 환경변수 (recovery-forest.evidence-base.ai)
# =============================================================
# 본 파일은 키 이름과 형식만 보여줍니다. 실제 값은 .env.local에 저장하세요.

# ---- Supabase ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # n8n / 서버 전용

# ---- 공공데이터포털 (산림청 등 통합 서비스 키) ----
DATA_GO_KR_SERVICE_KEY=<service-key>

# 산림청 치유의숲 / 둘레길 / 도시숲·자연휴양림 API URL
FOREST_HEALING_API_URL=https://api.forest.go.kr/openapi/service/...
FOREST_TRAIL_API_URL=https://api.forest.go.kr/openapi/service/...
URBAN_FOREST_API_URL=https://api.forest.go.kr/openapi/service/...

# ---- 기상청 단기예보 ----
KMA_API_KEY=<service-key>
KMA_SHORT_FORECAST_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0

# ---- 에어코리아 실시간 미세먼지 ----
AIRKOREA_API_KEY=<service-key>
AIRKOREA_REALTIME_URL=https://apis.data.go.kr/B552584/ArpltnInforInqireSvc

# ---- n8n Webhook ----
N8N_WEBHOOK_URL=https://n8n.evidence-base.ai/webhook/recovery-forest/recommend
N8N_WEBHOOK_SECRET=<shared-secret>
# Evidence Engine 처방 생성 (PRESCRIPTION_MODE=n8n 일 때)
N8N_PRESCRIBE_WEBHOOK_URL=https://n8n.evidence-base.ai/webhook/recovery-forest/prescribe

# ---- OpenAI (n8n 노드에서 사용) ----
OPENAI_API_KEY=sk-...

# ---- Evidence Engine 여정 ----
# 처방 생성 경로: stub=외부 API 없이 코드로 생성(데모 안전 기본값), n8n=n8n 워크플로우가 생성
PRESCRIPTION_MODE=stub

# 리포트 매직링크 이메일 발송 (선택). 없으면 무이메일 데모(같은 세션 리다이렉트)로 동작
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- 모니터링 (선택) ----
SENTRY_DSN=
